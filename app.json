{
  "expo": {
    "name": "Swing Music",
    "slug": "swing-music-ios",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "swingmusicios",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#121212",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121212",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      },
      "package": "com.swingmusicapp",
      "usesCleartextTraffic": true
    },
    "ios": {
      "bundleIdentifier": "com.swingmusicapp",
      "supportsTablet": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "plugins": [
      "expo-secure-store"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "43ce3547-cc15-4634-97aa-e43e0e0e840f"
      }
    }
  }
}
